#!/usr/bin/env bash
# glab-pipelines - Browse and open GitLab pipelines from terminal
# Usage: glab-pipelines [gitlab-url] [--branch|--all] [--cloudbees] [--diff]

set -e

# Colors
RED=$'\033[0;31m'
GREEN=$'\033[0;32m'
YELLOW=$'\033[1;33m'
BLUE=$'\033[0;34m'
CYAN=$'\033[0;36m'
MAGENTA=$'\033[0;35m'
BOLD=$'\033[1m'
NC=$'\033[0m'

# Parse args
MODE="branch"
CUSTOM_GITLAB_URL=""
CLOUDBEES=false
DIFF_MODE=false

while [[ $# -gt 0 ]]; do
    case "$1" in
        --all)
            MODE="all"
            shift
            ;;
        --branch)
            MODE="branch"
            shift
            ;;
        --cloudbees|-c)
            CLOUDBEES=true
            shift
            ;;
        --diff|-d)
            DIFF_MODE=true
            shift
            ;;
        -h|--help)
            echo "Usage: glab-pipelines [gitlab-url] [options]"
            echo ""
            echo "Args:"
            echo "  --branch    Show pipelines for current branch only (default)"
            echo "  --all       Show all pipelines for the project"
            echo "  --cloudbees Open CloudBees links instead of GitLab"
            echo "  --diff      Show git diff in preview (Enter=open, Ctrl-D=view diff)"
            echo "  -h, --help  Show this help"
            echo ""
            echo "Token: Uses GITLAB_TOKEN env var, or reads from macOS Keychain"
            exit 0
            ;;
        -*)
            echo "Unknown option: $1"
            exit 1
            ;;
        *)
            CUSTOM_GITLAB_URL="${1:-$CUSTOM_GITLAB_URL}"
            shift
            ;;
    esac
done

# Get token from keychain or env var
get_token() {
    local host="${1:-gitlab.com}"
    local token="${GITLAB_TOKEN:-${GLAB_TOKEN:-}}"
    
    if [[ -z "$token" ]]; then
        token=$(security find-internet-password -s "$host" 2>/dev/null | grep "password" | cut -d'"' -f4 || true)
    fi
    
    if [[ -z "$token" ]]; then
        echo -e "${RED}Error: GITLAB_TOKEN not set and no keychain entry found${NC}"
        exit 1
    fi
    echo "$token"
}

get_current_branch() {
    git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "main"
}

get_repo() {
    local remote
    remote=$(git remote get-url origin 2>/dev/null || git remote -v 2>/dev/null | head -1 | awk '{print $2}' || echo "")
    
    if [[ -z "$remote" ]]; then
        if [[ -n "$CUSTOM_GITLAB_URL" ]]; then
            remote="git@${CUSTOM_GITLAB_URL}:unknown/repo.git"
        else
            echo -e "${RED}Error: No git remote found${NC}"
            exit 1
        fi
    fi
    
    if [[ "$remote" =~ git@([^:]+):([^/]+)/(.+)\.git$ ]]; then
        host="${BASH_REMATCH[1]}"
        owner="${BASH_REMATCH[2]}"
        repo="${BASH_REMATCH[3]}"
    elif [[ "$remote" =~ https?://([^/]+)/([^/]+)/(.+?)(\.git)?$ ]]; then
        host="${BASH_REMATCH[1]}"
        owner="${BASH_REMATCH[2]}"
        repo="${BASH_REMATCH[3]}"
    else
        echo -e "${RED}Error: Could not parse git remote: $remote${NC}"
        exit 1
    fi
    
    if [[ -n "$CUSTOM_GITLAB_URL" ]]; then
        host="${CUSTOM_GITLAB_URL#https://}"
        host="${CUSTOM_GITLAB_URL#http://}"
        host="${host%%/*}"
    fi
    
    echo "$host $owner $repo"
}

get_status_icon() {
    case "$1" in
        success) echo "✓" ;;
        failed) echo "✗" ;;
        running) echo "◐" ;;
        pending) echo "○" ;;
        canceled) echo "⊘" ;;
        skipped) echo "⊝" ;;
        created) echo "◌" ;;
        *) echo "?" ;;
    esac
}

get_status_color() {
    case "$1" in
        success) echo "green" ;;
        failed) echo "red" ;;
        running) echo "blue" ;;
        pending) echo "yellow" ;;
        canceled) echo "yellow" ;;
        skipped) echo "white" ;;
        *) echo "white" ;;
    esac
}

fetch_pipelines() {
    local host="$1"
    local owner="$2"
    local repo="$3"
    local token="$4"
    local branch="$5"
    local limit="${6:-50}"
    
    local api_url="https://${host}/api/v4"
    local project_path="${owner}/${repo}"
    
    local url="${api_url}/projects/${project_path//\//%2F}/pipelines?per_page=${limit}"
    
    if [[ -n "$branch" ]]; then
        url+="&ref=${branch}"
    fi
    
    curl -s -H "PRIVATE-TOKEN: $token" "$url" 2>/dev/null
}

fetch_cloudbees_links() {
    local host="$1"
    local owner="$2"
    local repo="$3"
    local token="$4"
    local pipeline_id="$5"
    
    local api_url="https://${host}/api/v4"
    local project_path="${owner}/${repo}"
    
    local jobs
    jobs=$(curl -s -H "PRIVATE-TOKEN: $token" \
        "${api_url}/projects/${project_path//\//%2F}/pipelines/${pipeline_id}/jobs?per_page=50" 2>/dev/null)
    
    if [[ -z "$jobs" ]] || [[ "$jobs" == "[]" ]]; then
        return
    fi
    
    while IFS= read -r job; do
        local job_id
        job_id=$(echo "$job" | jq -r '.id // empty')
        
        [[ -z "$job_id" ]] && continue
        
        local trace
        trace=$(curl -s -H "PRIVATE-TOKEN: $token" \
            "${api_url}/projects/${project_path//\//%2F}/jobs/${job_id}/trace" 2>/dev/null | head -500)
        
        echo "$trace" | grep -oE 'https?://[^]"<>]+\.cloudbees\.com[^]"<>*' | sort -u
    done < <(echo "$jobs" | jq -c '.[]')
}

get_diff() {
    local ref="$1"
    local current_branch
    current_branch=$(get_current_branch)
    
    # Try to get diff between this ref and main/master
    local base_branch
    base_branch=$(git branch --list main master develop 2>/dev/null | head -1 | tr -d ' *' || echo "main")
    
    if [[ "$ref" == "$current_branch" ]]; then
        git diff "$base_branch...HEAD" --stat 2>/dev/null || git diff HEAD~10..HEAD --stat 2>/dev/null || echo "No diff available"
    else
        git diff "$base_branch...$ref" --stat 2>/dev/null || git diff "$ref~5..$ref" --stat 2>/dev/null || echo "No diff available"
    fi
}

main() {
    read -r host owner repo <<< "$(get_repo)"
    
    local token
    token=$(get_token "$host")
    
    local branch=""
    if [[ "$MODE" == "branch" ]]; then
        branch=$(get_current_branch)
    fi
    
    echo -e "${BLUE}${BOLD}GitLab Pipeline Browser${NC}"
    echo -e "${CYAN}Repo:${NC} ${owner}/${repo}"
    echo -e "${CYAN}Host:${NC} ${host}"
    [[ -n "$branch" ]] && echo -e "${CYAN}Branch:${NC} ${branch}" || echo -e "${CYAN}Mode:${NC} all pipelines"
    [[ "$CLOUDBEES" == "true" ]] && echo -e "${MAGENTA}CloudBees mode${NC}"
    [[ "$DIFF_MODE" == "true" ]] && echo -e "${MAGENTA}Diff preview enabled${NC}"
    echo ""
    
    local pipelines
    pipelines=$(fetch_pipelines "$host" "$owner" "$repo" "$token" "$branch" 30)
    
    if [[ -n "$pipelines" ]] && [[ ! "$pipelines" =~ ^\[ ]]; then
        echo -e "${YELLOW}API Response: $pipelines${NC}"
    fi
    
    if [[ -z "$pipelines" ]] || [[ "$pipelines" == "[]" ]]; then
        echo -e "${YELLOW}No pipelines found${NC}"
        exit 0
    fi
    
    if [[ "$pipelines" =~ \{.*message.*\} ]]; then
        echo -e "${RED}API Error: $pipelines${NC}"
        exit 1
    fi
    
    local fzf_entries=""
    while IFS= read -r line; do
        local id status ref created_at web_url
        id=$(echo "$line" | jq -r '.id // empty')
        status=$(echo "$line" | jq -r '.status // empty')
        ref=$(echo "$line" | jq -r '.ref // empty')
        created_at=$(echo "$line" | jq -r '.created_at // empty')
        web_url=$(echo "$line" | jq -r '.web_url // empty')
        
        ref="${ref:0:40}"
        
        local date
        if [[ -n "$created_at" ]]; then
            date=$(date -j -f "%Y-%m-%dT%H:%M:%S%z" "$created_at" "+%m/%d %H:%M" 2>/dev/null || echo "${created_at:0:16}")
        else
            date="--/--"
        fi
        
        local icon color
        icon=$(get_status_icon "$status")
        color=$(get_status_color "$status")
        
        local extra=""
        if [[ "$CLOUDBEES" == "true" ]]; then
            local cb_links
            cb_links=$(fetch_cloudbees_links "$host" "$owner" "$repo" "$token" "$id")
            if [[ -n "$cb_links" ]]; then
                echo "$cb_links" > "/tmp/cb_${id}.txt"
                extra=" | $(echo "$cb_links" | head -1)"
            else
                extra=" | (no CB)"
            fi
        fi
        
        local id_color
        if [[ "$status" == "failed" ]]; then
            id_color="$RED"
        else
            id_color="$GREEN"
        fi
        
        # Simplified: just icon, #id, branch, date (no status text)
        local entry
        entry="${icon} ${id_color}#${id}${NC} | ${CYAN}${ref}${NC} | ${date}${extra} | ${web_url}"
        
        fzf_entries+="$entry"$'\n'
    done < <(echo "$pipelines" | jq -c '.[]')
    
    local fzf_opts=(
        --prompt="Select: "
        --preview-window=hidden
        --height=20
        --reverse
        --ansi
    )
    
    if [[ "$DIFF_MODE" == "true" ]]; then
        # Preview with diff stats
        fzf_opts+=(
            --preview="echo {} | grep -oP '#\K[0-9]+' | head -1 | xargs -I{} sh -c 'git log --oneline -5 2>/dev/null | head -20 || echo \"No diff\"'"
        )
    fi
    
    local selected
    selected=$(echo "$fzf_entries" | fzf "${fzf_opts[@]}")
    
    [[ -z "$selected" ]] && exit 0
    
    local url
    url=$(echo "$selected" | sed 's/.*| //')
    
    if [[ "$CLOUDBEES" == "true" ]]; then
        local pipeline_id
        pipeline_id=$(echo "$selected" | grep -oP '#\K[0-9]+' | head -1)
        
        if [[ -n "$pipeline_id" ]] && [[ -f "/tmp/cb_${pipeline_id}.txt" ]]; then
            local cb_links link_count
            cb_links=$(cat "/tmp/cb_${pipeline_id}.txt" | sort -u)
            link_count=$(echo "$cb_links" | grep -c . || echo 0)
            
            if [[ "$link_count" -gt 1 ]]; then
                echo -e "${CYAN}Multiple CloudBees links:${NC}"
                local chosen_link
                chosen_link=$(echo "$cb_links" | fzf --prompt="Select: " --height=15 --reverse)
                [[ -n "$chosen_link" ]] && url="$chosen_link"
            elif [[ "$link_count" -eq 1 ]]; then
                url=$(echo "$cb_links" | head -1)
            fi
            
            rm -f "/tmp/cb_${pipeline_id}.txt"
        fi
    fi
    
    echo -e "${GREEN}→ Opening:${NC} $url"
    open "$url"
}

main
