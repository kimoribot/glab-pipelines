#!/usr/bin/env bash
# glab-pipelines - Browse and open GitLab pipelines from terminal
# Usage: glab-pipelines [gitlab-url] [--branch | --all]
#   or: glab-pipelines gitlab.mycompany.com

set -e

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
BOLD='\033[1m'
NC='\033[0m' # No Color

# Parse args
MODE="branch"  # default to current branch
CUSTOM_GITLAB_URL=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --all)
            MODE="all"
            shift
            ;;
        --branch)
            MODE="branch"
            shift
            ;;
        -h|--help)
            echo "Usage: glab-pipelines [gitlab-url] [--branch|--all]"
            echo ""
            echo "Args:"
            echo "  --branch    Show pipelines for current branch only (default)"
            echo "  --all       Show all pipelines for the project"
            exit 0
            ;;
        -*)
            echo "Unknown option: $1"
            exit 1
            ;;
        *)
            CUSTOM_GITLAB_URL="$1"
            shift
            ;;
    esac
done

# Get token
get_token() {
    local token="${GITLAB_TOKEN:-${GLAB_TOKEN:-}}"
    if [[ -z "$token" ]]; then
        echo -e "${RED}Error: GITLAB_TOKEN or GLAB_TOKEN not set${NC}"
        echo "Set it with: export GITLAB_TOKEN=your_token"
        echo "Get a token at: https://gitlab.com/-/profile/personal_access_tokens"
        exit 1
    fi
    echo "$token"
}

# Get current branch
get_current_branch() {
    git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "main"
}

# Get repo info from git
get_repo() {
    local remote
    remote=$(git remote get-url origin 2>/dev/null || git remote -v 2>/dev/null | head -1 | awk '{print $2}' || echo "")
    
    if [[ -z "$remote" ]]; then
        echo -e "${RED}Error: No git remote found${NC}"
        exit 1
    fi
    
    # Parse git@host:owner/repo.git or https://host/owner/repo.git
    if [[ "$remote" =~ git@([^:]+):([^/]+)/(.+)\.git$ ]]; then
        host="${BASH_REMATCH[1]}"
        owner="${BASH_REMATCH[2]}"
        repo="${BASH_REMATCH[3]}"
    elif [[ "$remote" =~ https?://([^/]+)/([^/]+)/(.+?)(\.git)?$ ]]; then
        host="${BASH_REMATCH[1]}"
        owner="${BASH_REMATCH[2]}"
        repo="${BASH_REMATCH[3]}"
    else
        echo -e "${RED}Error: Could not parse git remote: $remote${NC}"
        exit 1
    fi
    
    # Override host if custom URL provided
    if [[ -n "$CUSTOM_GITLAB_URL" ]]; then
        host="${CUSTOM_GITLAB_URL#https://}"
        host="${CUSTOM_GITLAB_URL#http://}"
        host="${host%%/*}"
    fi
    
    echo "$host $owner $repo"
}

# Get pipeline status color for fzf
get_status_color() {
    case "$1" in
        success) echo "green" ;;
        failed) echo "red" ;;
        running) echo "blue" ;;
        pending) echo "yellow" ;;
        canceled) echo "yellow" ;;
        skipped) echo "white" ;;
        *) echo "white" ;;
    esac
}

# Get pipeline status icon
get_status_icon() {
    case "$1" in
        success) echo "✓" ;;
        failed) echo "✗" ;;
        running) echo "◐" ;;
        pending) echo "○" ;;
        canceled) echo "⊘" ;;
        skipped) echo "⊝" ;;
        created) echo "◌" ;;
        *) echo "?" ;;
    esac
}

# Fetch pipelines
fetch_pipelines() {
    local host="$1"
    local owner="$2"
    local repo="$3"
    local token="$4"
    local branch="$5"
    local limit="${6:-50}"
    
    local api_url="https://${host}/api/v4"
    local project_path="${owner}/${repo}"
    
    local url="${api_url}/projects/${project_path//\//%2F}/pipelines?per_page=${limit}"
    
    # Filter by branch if specified
    if [[ -n "$branch" ]]; then
        url+="&ref=${branch}"
    fi
    
    curl -s -H "PRIVATE-TOKEN: $token" "$url" 2>/dev/null
}

# Main
main() {
    local token
    token=$(get_token)
    
    # Get repo info
    read -r host owner repo <<< "$(get_repo)"
    
    # Get current branch if in branch mode
    local branch=""
    if [[ "$MODE" == "branch" ]]; then
        branch=$(get_current_branch)
    fi
    
    echo -e "${BLUE}${BOLD}GitLab Pipeline Browser${NC}"
    echo -e "${CYAN}Repo:${NC} ${owner}/${repo}"
    echo -e "${CYAN}Host:${NC} ${host}"
    if [[ -n "$branch" ]]; then
        echo -e "${CYAN}Branch:${NC} ${branch}"
    else
        echo -e "${CYAN}Mode:${NC} all pipelines"
    fi
    echo ""
    
    # Fetch pipelines
    local pipelines
    pipelines=$(fetch_pipelines "$host" "$owner" "$repo" "$token" "$branch" 30)
    
    if [[ -n "$pipelines" ]] && [[ ! "$pipelines" =~ ^\[ ]]; then
        echo -e "${YELLOW}API Response: $pipelines${NC}"
    fi
    
    if [[ -z "$pipelines" ]] || [[ "$pipelines" == "[]" ]]; then
        echo -e "${YELLOW}No pipelines found${NC}"
        exit 0
    fi
    
    if [[ "$pipelines" =~ \{.*message.*\} ]]; then
        echo -e "${RED}API Error: $pipelines${NC}"
        exit 1
    fi
    
    # Build fzf input with ANSI colors for fzf
    local fzf_entries=""
    while IFS= read -r line; do
        local id status ref created_at web_url
        id=$(echo "$line" | jq -r '.id // empty')
        status=$(echo "$line" | jq -r '.status // empty')
        ref=$(echo "$line" | jq -r '.ref // empty')
        created_at=$(echo "$line" | jq -r '.created_at // empty')
        web_url=$(echo "$line" | jq -r '.web_url // empty')
        
        ref="${ref:0:35}"
        
        # Format date
        if [[ -n "$created_at" ]]; then
            local date
            date=$(date -j -f "%Y-%m-%dT%H:%M:%S%z" "$created_at" "+%m/%d %H:%M" 2>/dev/null || echo "${created_at:0:16}")
        else
            date="--/-- --:--"
        fi
        
        local icon color
        icon=$(get_status_icon "$status")
        color=$(get_status_color "$status")
        
        # ANSI colored entry for fzf (it parses ANSI codes)
        # Format: [status_icon #id | branch | date | status]
        printf -v entry "%s ${GREEN}#%s${NC} | ${CYAN}%s${NC} | %s | ${!color}%s${NC}" \
            "$icon" "$id" "$ref" "$date" "$status"
        
        # Append URL as hidden field (last field after |)
        entry="${entry} | ${web_url}"
        
        fzf_entries+="$entry"$'\n'
    done < <(echo "$pipelines" | jq -c '.[]')
    
    # Run fzf with color support
    local selected
    selected=$(echo "$fzf_entries" | FZF_DEFAULT_OPTS="--color=fg:-1" fzf \
        --prompt="Select pipeline: " \
        --header="${BOLD}↑↓ navigate${NC} | ${BOLD}ENTER${NC} open | ${BOLD}ESC${NC} exit" \
        --header-lines=1 \
        --preview-window=hidden \
        --height=20 \
        --reverse \
        --ansi)
    
    if [[ -z "$selected" ]]; then
        exit 0
    fi
    
    # Extract URL (last field after last |)
    local url
    url=$(echo "$selected" | sed 's/.*| //')
    
    echo -e "${GREEN}→ Opening:${NC} $url"
    open "$url"
}

main
